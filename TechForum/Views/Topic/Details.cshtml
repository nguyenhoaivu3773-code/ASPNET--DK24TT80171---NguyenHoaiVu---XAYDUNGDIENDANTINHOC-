<section class="main-content920 topic-detail-page">
    <div class="container-fluid topic-detail-container">

        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert alert-success">
                @TempData["SuccessMessage"]
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="alert alert-danger">
                @TempData["ErrorMessage"]
            </div>
        }

        <div class="row">
            <div class="col-md-9">

                <div class="post-details">
                    <div class="details-header923">
                        <div class="row">
                            <div class="col-md-8">
                                <div class="post-title-left129">
                                    <h3>@Model.Topic.Title</h3>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="post-details-info1982">
                        <p class="topic-detail-content">@Model.Topic.Content</p>

                        @if (Model.Topic.TopicTags != null && Model.Topic.TopicTags.Any())
                        {
                            <div class="topic-detail-tags">
                                @foreach (var item in Model.Topic.TopicTags)
                                {
                                    <a href="@Url.Action("Index", "Topic", new { tagId = item.Tag.Id })"
                                       class="topic-detail-tag">
                                        @item.Tag.Name
                                    </a>
                                }
                            </div>
                        }

                        <hr />

                        <div class="post-footer29032">
                            <div class="l-side2023">

                                <i class="fa fa-star star2" aria-hidden="true">
                                    @Model.Topic.VoteCount vote
                                </i>

                                <i class="fa fa-clock-o clock2" aria-hidden="true">
                                    @Model.Topic.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                </i>

                                <a href="#comments-list">
                                    <i class="fa fa-commenting commenting2" aria-hidden="true">
                                        @(Model.ParentComments != null ? Model.ParentComments.Count : 0) trả lời
                                    </i>
                                </a>

                                <i class="fa fa-user user2" aria-hidden="true">
                                    @Model.Topic.ViewCount views
                                </i>
                            </div>
                        </div>

                        <div class="topic-action-row">
                            @if (Session["UserId"] != null)
                            {
                                if (Model.HasVoted)
                                {
                                    <button class="topic-btn topic-btn-voted" disabled>
                                        <i class="fa fa-check"></i> Đã vote
                                    </button>
                                }
                                else
                                {
                                    <form action="@Url.Action("Vote", "Topic")" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="topicId" value="@Model.Topic.Id" />

                                        <button type="submit" class="topic-btn topic-btn-vote">
                                            <i class="fa fa-thumbs-o-up"></i> Vote chủ đề
                                        </button>
                                    </form>
                                }

                                <button type="button"
                                        class="topic-btn topic-btn-report"
                                        id="btnShowReportForm2">
                                    <i class="fa fa-flag"></i> Báo cáo chủ đề
                                </button>
                            }
                            else
                            {
                                <a href="@Url.Action("Login", "Account", new { returnUrl = Request.RawUrl })" class="topic-btn topic-btn-login">
                                    <i class="fa fa-sign-in"></i> Đăng nhập để vote
                                </a>

                                <a href="@Url.Action("Login", "Account", new { returnUrl = Request.RawUrl })" class="topic-btn topic-btn-login">
                                    <i class="fa fa-sign-in"></i> Đăng nhập để báo cáo
                                </a>
                            }
                        </div>
                    </div>
                </div>

                @if (Session["UserId"] != null)
                {
                    <div id="reportFormBox" class="report-box" style="display:none;">
                        <h5>
                            <i class="fa fa-flag"></i>
                            Báo cáo chủ đề vi phạm
                        </h5>

                        <form action="@Url.Action("Report", "Topic")" method="post">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="topicId" value="@Model.Topic.Id" />

                            <div class="form-group">
                                <label for="reason">Lý do báo cáo</label>
                                <textarea name="reason"
                                          id="reason"
                                          class="form-control"
                                          rows="4"
                                          maxlength="500"
                                          placeholder="Ví dụ: Nội dung sai sự thật, spam, xúc phạm người khác, không phù hợp với diễn đàn..."></textarea>
                            </div>

                            <button type="submit" class="topic-btn topic-btn-report">
                                Gửi báo cáo
                            </button>

                            <button type="button"
                                    class="topic-btn"
                                    id="btnCancelReport"
                                    style="background:#777;color:#fff;">
                                Hủy
                            </button>
                        </form>
                    </div>
                }

                @if (Model.Topic.TopicImages != null && Model.Topic.TopicImages.Any())
                {
                    <div class="row topic-images-row">
                        @foreach (var image in Model.Topic.TopicImages)
                        {
                            <div class="col-md-4 col-sm-6 topic-image-item">
                                <img src="@image.ImagePath" alt="Topic image" />
                            </div>
                        }
                    </div>
                }

                <h4 class="topic-section-title">Trả lời chủ đề</h4>

                @if (Session["UserId"] != null)
                {
                    <div class="topic-answer-box">
                        <form action="@Url.Action("AddComment", "Topic")" method="post">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="topicId" value="@Model.Topic.Id" />

                            <div class="form-group">
                                <textarea name="content"
                                          class="form-control"
                                          rows="4"
                                          placeholder="Nhập câu trả lời của bạn..."></textarea>
                            </div>

                            <button type="submit" class="topic-submit-comment-btn">
                                <i class="fa fa-paper-plane"></i> Gửi trả lời
                            </button>
                        </form>
                    </div>
                }
                else
                {
                    <div class="alert alert-info">
                        Vui lòng <a href="@Url.Action("Login", "Account", new { returnUrl = Request.RawUrl })">đăng nhập</a> để trả lời chủ đề.
                    </div>
                }

                <h4 class="topic-section-title">Danh sách thảo luận</h4>

                <div class="comment-list12993">
                    <div class="comments-container">

                        @if (Model.ParentComments == null || !Model.ParentComments.Any())
                        {
                            <div class="alert alert-info">
                                Chưa có trả lời nào cho chủ đề này.
                            </div>
                        }
                        else
                        {
                            int parentCommentIndex = 0;

                            <ul id="comments-list" class="comments-list">
                                @foreach (var comment in Model.ParentComments)
                                {
                                    string parentCommentClass = parentCommentIndex >= 3 ? "hidden-comment-item" : "";

                                    string commentAvatar = comment.User != null && !string.IsNullOrEmpty(comment.User.Avatar)
                                        ? Url.Content(comment.User.Avatar)
                                        : Url.Content("~/Uploads/Avatars/default-avatar.png");

                                    string commentUserName = comment.User != null ? comment.User.FullName : "Ẩn danh";
                                    bool isCommentAdmin = comment.User != null && comment.User.Role == "Admin";

                                    <li class="parent-comment-item @parentCommentClass">
                                        <div class="comment-main-level">
                                            <div class="comment-avatar">
                                                <img src="@commentAvatar" alt="@commentUserName" />
                                            </div>

                                            <div class="comment-box">
                                                <div class="comment-head">
                                                    <h6 class="comment-name @(isCommentAdmin ? "by-author" : "")">
                                                        <a href="#">
                                                            @commentUserName
                                                        </a>
                                                    </h6>

                                                    <span>
                                                        <i class="fa fa-clock-o" aria-hidden="true">
                                                            @comment.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                                        </i>
                                                    </span>

                                                    @if (Session["UserId"] != null)
                                                    {
                                                        <button type="button"
                                                                class="reply-toggle"
                                                                data-target="reply-form-@comment.Id">
                                                            <i class="fa fa-reply"></i> Bình luận
                                                        </button>
                                                    }

                                                    <i class="fa fa-heart"></i>
                                                </div>

                                                <div class="comment-content">
                                                    @comment.Content
                                                </div>

                                                @if (Session["UserId"] != null)
                                                {
                                                    <form action="@Url.Action("AddComment", "Topic")"
                                                          method="post"
                                                          id="reply-form-@comment.Id"
                                                          class="reply-form"
                                                          style="display:none;">
                                                        @Html.AntiForgeryToken()

                                                        <input type="hidden" name="topicId" value="@Model.Topic.Id" />
                                                        <input type="hidden" name="parentCommentId" value="@comment.Id" />

                                                        <textarea name="content"
                                                                  class="form-control"
                                                                  rows="2"
                                                                  placeholder="Nhập bình luận của bạn..."></textarea>

                                                        <button type="submit" class="reply-submit-btn">
                                                            Gửi bình luận
                                                        </button>
                                                    </form>
                                                }
                                            </div>
                                        </div>

                                        @if (comment.Replies != null && comment.Replies.Any())
                                        {
                                            int replyIndex = 0;

                                            <ul class="comments-list reply-list">
                                                @foreach (var reply in comment.Replies)
                                                {
                                                    string replyClass = replyIndex >= 3 ? "hidden-reply-item" : "";

                                                    string replyAvatar = reply.User != null && !string.IsNullOrEmpty(reply.User.Avatar)
                                                        ? Url.Content(reply.User.Avatar)
                                                        : Url.Content("~/Uploads/Avatars/default-avatar.png");

                                                    string replyUserName = reply.User != null ? reply.User.FullName : "Ẩn danh";
                                                    bool isReplyAdmin = reply.User != null && reply.User.Role == "Admin";

                                                    <li class="reply-comment-item @replyClass">
                                                        <div class="comment-avatar">
                                                            <img src="@replyAvatar" alt="@replyUserName" />
                                                        </div>

                                                        <div class="comment-box">
                                                            <div class="comment-head">
                                                                <h6 class="comment-name @(isReplyAdmin ? "by-author" : "")">
                                                                    <a href="#">
                                                                        @replyUserName
                                                                    </a>
                                                                </h6>

                                                                <span>
                                                                    <i class="fa fa-clock-o" aria-hidden="true">
                                                                        @reply.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                                                    </i>
                                                                </span>

                                                                <i class="fa fa-heart"></i>
                                                            </div>

                                                            <div class="comment-content">
                                                                @reply.Content
                                                            </div>
                                                        </div>
                                                    </li>

                                                    replyIndex++;
                                                }
                                            </ul>

                                            if (comment.Replies.Count > 3)
                                            {
                                                <button type="button"
                                                        class="load-more-replies-btn">
                                                    Xem thêm trả lời
                                                </button>
                                            }
                                        }
                                    </li>

                                    parentCommentIndex++;
                                }
                            </ul>

                            if (Model.ParentComments.Count > 3)
                            {
                                <button type="button"
                                        id="btnLoadMoreComments"
                                        class="load-more-comments-btn">
                                    Xem thêm trả lời
                                </button>
                            }
                        }

                    </div>
                </div>

                <a href="@Url.Action("Index", "Topic")" class="topic-back-btn">
                    <i class="fa fa-arrow-left"></i> Quay lại danh sách
                </a>
            </div>

            <aside class="col-md-3 sidebar97239">

                <div class="topic-sidebar-box highest-part302">
                    <h4>Tác giả</h4>

                    <div class="author-box">
                        <img src="@authorAvatar"
                             alt="@authorName"
                             class="author-avatar" />

                        @if (Model.Topic.User != null)
                        {
                            <a href="@Url.Action("Details", "User", new { id = Model.Topic.User.Id })"
                               class="author-name">
                                @authorName
                            </a>

                            if (Model.Topic.User.Role == "Admin")
                            {
                                <span class="author-role-badge">admin</span>
                            }
                        }
                        else
                        {
                            <span class="author-name">@authorName</span>
                        }
                    </div>
                </div>

                <div class="topic-sidebar-box highest-part302">
                    <h4>Chủ đề nổi bật của @authorName</h4>

                    @if (Model.AuthorTopVotedTopics == null || !Model.AuthorTopVotedTopics.Any())
                    {
                        <div class="text-muted">
                            Tác giả này chưa có chủ đề nổi bật khác.
                        </div>
                    }
                    else
                    {
                        foreach (var item in Model.AuthorTopVotedTopics)
                        {
                            <div class="pints-wrapper">
                                <div class="left-user3898">
                                    <a href="@Url.Action("Details", "Topic", new { id = item.Id })">
                                        <img src="@authorAvatar" alt="@authorName" />
                                    </a>
                                </div>

                                <span class="points-details938">
                                    <a href="@Url.Action("Details", "Topic", new { id = item.Id })">
                                        <h5>@item.Title</h5>
                                    </a>

                                    <span class="designetion439">
                                        <i class="fa fa-star"></i>
                                        @item.VoteCount vote
                                    </span>

                                    <p>
                                        <i class="fa fa-eye"></i>
                                        @item.ViewCount xem ·
                                        <i class="fa fa-comment"></i>
                                        @item.CommentCount trả lời
                                    </p>

                                    <p>
                                        <i class="fa fa-clock-o"></i>
                                        @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                    </p>

                                    @if (item.Tags != null && item.Tags.Any())
                                    {
                                        foreach (var tag in item.Tags)
                                        {
                                            <a href="@Url.Action("Index", "Topic", new { tagId = tag.Id })"
                                               class="author-topic-tag">
                                                @tag.Name
                                            </a>
                                        }
                                    }
                                </span>
                            </div>
                        }
                    }
                </div>

            </aside>
        </div>
    </div>
</section>

@section scripts {
    <script>
        (function () {
            var buttons = document.querySelectorAll(".reply-toggle");

            buttons.forEach(function (button) {
                button.addEventListener("click", function () {
                    var targetId = this.getAttribute("data-target");
                    var form = document.getElementById(targetId);

                    if (!form) {
                        return;
                    }

                    if (form.style.display === "none" || form.style.display === "") {
                        form.style.display = "block";
                    } else {
                        form.style.display = "none";
                    }
                });
            });

            var reportButton = document.getElementById("btnShowReportForm");
            var reportButton2 = document.getElementById("btnShowReportForm2");
            var reportBox = document.getElementById("reportFormBox");
            var cancelReportButton = document.getElementById("btnCancelReport");

            function showReportBox() {
                if (reportBox) {
                    reportBox.style.display = "block";
                    reportBox.scrollIntoView({ behavior: "smooth", block: "center" });
                }
            }

            if (reportButton) {
                reportButton.addEventListener("click", showReportBox);
            }

            if (reportButton2) {
                reportButton2.addEventListener("click", showReportBox);
            }

            if (cancelReportButton && reportBox) {
                cancelReportButton.addEventListener("click", function () {
                    reportBox.style.display = "none";
                });
            }

            var loadMoreCommentsButton = document.getElementById("btnLoadMoreComments");

            if (loadMoreCommentsButton) {
                loadMoreCommentsButton.addEventListener("click", function () {
                    var hiddenComments = document.querySelectorAll(".hidden-comment-item");

                    for (var i = 0; i < 3 && i < hiddenComments.length; i++) {
                        hiddenComments[i].classList.remove("hidden-comment-item");
                    }

                    if (document.querySelectorAll(".hidden-comment-item").length === 0) {
                        loadMoreCommentsButton.style.display = "none";
                    }
                });
            }

            var loadMoreRepliesButtons = document.querySelectorAll(".load-more-replies-btn");

            loadMoreRepliesButtons.forEach(function (button) {
                button.addEventListener("click", function () {
                    var replyList = this.previousElementSibling;

                    if (!replyList || !replyList.classList.contains("reply-list")) {
                        return;
                    }

                    var hiddenReplies = replyList.querySelectorAll(".hidden-reply-item");

                    for (var i = 0; i < 3 && i < hiddenReplies.length; i++) {
                        hiddenReplies[i].classList.remove("hidden-reply-item");
                    }

                    if (replyList.querySelectorAll(".hidden-reply-item").length === 0) {
                        this.style.display = "none";
                    }
                });
            });
        })();
    </script>
}