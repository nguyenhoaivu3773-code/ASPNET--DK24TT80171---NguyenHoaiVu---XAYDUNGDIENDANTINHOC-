@model TechForum.Models.RegisterVM

@{
    ViewBag.Title = "Đăng ký";
}

@section styles {
    <style>
        .register-page-wrapper {
            min-height: calc(100vh - 140px);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 45px 15px;
            background: linear-gradient(135deg, #f5f7fa 0%, #eef2f7 100%);
        }

        .register-card {
            width: 100%;
            max-width: 520px;
            background: #fff;
            border-radius: 8px;
            box-shadow: 0 10px 35px rgba(0, 0, 0, 0.08);
            padding: 35px 35px 30px;
            border-top: 4px solid #f48024;
        }

            .register-card .title {
                text-align: center;
                font-size: 28px;
                font-weight: 700;
                color: #2c3e50;
                margin-bottom: 8px;
            }

            .register-card .description {
                text-align: center;
                color: #777;
                margin-bottom: 25px;
                font-size: 14px;
            }

            .register-card .form-group {
                margin-bottom: 17px;
            }

            .register-card label {
                font-weight: 600;
                color: #333;
                margin-bottom: 7px;
            }

            .register-card .form-control {
                height: 42px;
                border-radius: 4px;
                border: 1px solid #ddd;
                box-shadow: none;
            }

                .register-card .form-control:focus {
                    border-color: #f48024;
                    box-shadow: 0 0 0 2px rgba(244, 128, 36, 0.12);
                }

            .register-card input[type="file"].form-control {
                height: auto;
                padding: 8px 12px;
            }

        .avatar-hint {
            color: #777;
            font-size: 13px;
            margin-top: 6px;
        }

        .register-submit-btn {
            width: 100%;
            height: 42px;
            background: #f48024;
            border: none;
            color: #fff;
            font-weight: 700;
            border-radius: 4px;
            text-transform: uppercase;
            letter-spacing: 0.4px;
            margin-top: 5px;
        }

            .register-submit-btn:hover,
            .register-submit-btn:focus {
                background: #d96d17;
                color: #fff;
            }

        .register-login-link {
            text-align: center;
            margin-top: 20px;
            color: #666;
        }

            .register-login-link a {
                color: #f48024;
                font-weight: 600;
            }

                .register-login-link a:hover {
                    color: #d96d17;
                    text-decoration: none;
                }

        .text-danger {
            font-size: 13px;
        }

        @@media (max-width: 480px) {
            .register-card {
                padding: 28px 22px 25px;
            }

                .register-card .title {
                    font-size: 24px;
                }
        }
    </style>
}

<section class="register-page-wrapper">
    <div class="register-card">

        <div class="title">Đăng ký tài khoản</div>
        <div class="description">Tạo tài khoản để tham gia diễn đàn tin học</div>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger">
                Vui lòng kiểm tra lại thông tin đăng ký.
            </div>
        }

        <form action="@Url.Action("Register", "Account")" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="FullName">Họ tên</label>
                <input type="text"
                       name="FullName"
                       id="FullName"
                       class="form-control"
                       placeholder="Nhập họ tên"
                       value="@(Model != null ? Model.FullName : "")" />

                @Html.ValidationMessage("FullName", "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label for="Email">Email</label>
                <input type="email"
                       name="Email"
                       id="Email"
                       class="form-control"
                       placeholder="Nhập email"
                       value="@(Model != null ? Model.Email : "")" />

                @Html.ValidationMessage("Email", "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label for="Password">Mật khẩu</label>
                <input type="password"
                       name="Password"
                       id="Password"
                       class="form-control"
                       placeholder="Nhập mật khẩu" />

                @Html.ValidationMessage("Password", "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label for="ConfirmPassword">Nhập lại mật khẩu</label>
                <input type="password"
                       name="ConfirmPassword"
                       id="ConfirmPassword"
                       class="form-control"
                       placeholder="Nhập lại mật khẩu" />

                @Html.ValidationMessage("ConfirmPassword", "", new { @class = "text-danger" })
            </div>

            <div class="form-group">
                <label for="AvatarFile">Ảnh đại diện</label>
                <input type="file"
                       name="AvatarFile"
                       id="AvatarFile"
                       class="form-control"
                       accept=".jpg,.jpeg,.png,.gif" />

                <div class="avatar-hint">
                    Chấp nhận ảnh JPG, PNG hoặc GIF. Có thể bỏ trống nếu chưa muốn tải ảnh.
                </div>

                @Html.ValidationMessage("AvatarFile", "", new { @class = "text-danger" })
            </div>

            <button type="submit" class="register-submit-btn">
                Đăng ký
            </button>
        </form>

        <div class="register-login-link">
            Đã có tài khoản?
            <a href="@Url.Action("Login", "Account")">Đăng nhập</a>
        </div>

    </div>
</section>