@model IEnumerable<TechForum.Models.AdminUserItemVM>

@{
    ViewBag.Title = "Quản lý người dùng";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<section class="content-header">
    <div class="content-header-left">
        <h1>Quản lý người dùng</h1>
    </div>
</section>

<section class="content">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <i class="fa fa-check"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            <i class="fa fa-warning"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="row">
        <div class="col-md-12">

            <div class="box box-info">

                <div class="box-header with-border">
                    <h3 class="box-title">Danh sách người dùng</h3>
                </div>

                <div class="box-body table-responsive">

                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-info">
                            Chưa có người dùng nào.
                        </div>
                    }
                    else
                    {
                        <table id="example1" class="table table-bordered table-hover table-striped">
                            <thead>
                                <tr>
                                    <th width="10">#</th>
                                    <th>Tên người dùng</th>
                                    <th>Email</th>
                                    <th width="100">Vai trò</th>
                                    <th width="120">Số chủ đề</th>
                                    <th width="140">Trạng thái</th>
                                    <th width="150">Thao tác</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    var index = 0;
                                }

                                @foreach (var user in Model)
                                {
                                    index++;

                                    <tr>
                                        <td>@index</td>

                                        <td>
                                            <strong>@user.FullName</strong>
                                        </td>

                                        <td>@user.Email</td>

                                        <td>
                                            @if (user.Role == "Admin")
                                            {
                                                <span class="badge" style="background-color:red;">
                                                    Admin
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge" style="background-color:#3c8dbc;">
                                                    User
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            <strong>@user.TotalTopics</strong>
                                        </td>

                                        <td>
                                            @if (user.IsActive)
                                            {
                                                <span class="badge" style="background-color:green;">
                                                    Đang hoạt động
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge" style="background-color:red;">
                                                    Đã khóa
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            @if (user.Role == "Admin")
                                            {
                                                <button class="btn btn-default btn-xs" disabled>
                                                    Không áp dụng
                                                </button>
                                            }
                                            else
                                            {
                                                using (Html.BeginForm("ToggleUserStatus", "Admin", FormMethod.Post, new { style = "display:inline;" }))
                                                {
                                                    @Html.AntiForgeryToken()

                                                    <input type="hidden" name="id" value="@user.Id" />

                                                    if (user.IsActive)
                                                    {
                                                        <button type="submit"
                                                                class="btn btn-danger btn-xs"
                                                                onclick="return confirm('Bạn có chắc muốn khóa tài khoản này không?');">
                                                            <i class="fa fa-lock"></i> Khóa
                                                        </button>
                                                    }
                                                    else
                                                    {
                                                        <button type="submit"
                                                                class="btn btn-success btn-xs"
                                                                onclick="return confirm('Bạn có chắc muốn mở khóa tài khoản này không?');">
                                                            <i class="fa fa-unlock"></i> Mở khóa
                                                        </button>
                                                    }
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                </div>
            </div>

        </div>
    </div>
</section>