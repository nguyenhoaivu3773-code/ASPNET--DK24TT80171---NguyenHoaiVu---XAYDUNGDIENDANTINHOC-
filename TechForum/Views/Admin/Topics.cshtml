@model IEnumerable<TechForum.Models.AdminTopicItemVM>

@{
    ViewBag.Title = "Quản lý chủ đề";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<section class="content-header">
    <div class="content-header-left">
        <h1>Quản lý chủ đề</h1>
    </div>

</section>

<section class="content">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <i class="fa fa-check"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            <i class="fa fa-warning"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="row">
        <div class="col-md-12">

            <div class="box box-info">

                <div class="box-header with-border">
                    <h3 class="box-title">Danh sách chủ đề</h3>
                </div>

                <div class="box-body table-responsive">

                    @if (Model == null || !Model.Any())
                    {
                        <div class="alert alert-info">
                            Chưa có chủ đề nào trong hệ thống.
                        </div>
                    }
                    else
                    {
                        <table id="example1" class="table table-bordered table-hover table-striped">
                            <thead>
                                <tr>
                                    <th width="10">#</th>
                                    <th>Chủ đề</th>
                                    <th width="150">Người tạo</th>
                                    <th width="140">Ngày tạo</th>
                                    <th width="150">Thống kê</th>
                                    <th width="120">Trạng thái</th>
                                    <th width="130">Thao tác</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    var index = 0;
                                }

                                @foreach (var topic in Model)
                                {
                                    index++;

                                    <tr>
                                        <td>@index</td>

                                        <td>
                                            <strong>@topic.Title</strong>
                                            <br />
                                            <span class="text-muted">
                                                @topic.ShortContent
                                            </span>
                                        </td>

                                        <td>
                                            @topic.UserFullName
                                        </td>

                                        <td>
                                            @topic.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                        </td>

                                        <td>
                                            <span>Lượt xem: <strong>@topic.ViewCount</strong></span>
                                            <br />
                                            <span>Vote: <strong>@topic.VoteCount</strong></span>
                                            <br />
                                            <span>Bình luận: <strong>@topic.CommentCount</strong></span>
                                        </td>

                                        <td>
                                            @if (topic.IsDeleted)
                                            {
                                                <span class="badge" style="background-color:red;">
                                                    Đã ẩn
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge" style="background-color:green;">
                                                    Đang hiển thị
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            <a href="@Url.Action("Details", "Topic", new { id = topic.Id })"
                                               class="btn btn-primary btn-xs"
                                               target="_blank">
                                                <i class="fa fa-eye"></i> Xem
                                            </a>

                                            @using (Html.BeginForm("DeleteTopic", "Admin", FormMethod.Post, new { style = "display:inline;" }))
                                            {
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@topic.Id" />

                                                <button type="submit"
                                                        class="btn btn-danger btn-xs"
                                                        onclick="return confirm('Bạn có chắc muốn xóa chủ đề này không? Dữ liệu liên quan như ảnh, vote, bình luận và báo cáo cũng sẽ bị xóa.');">
                                                    <i class="fa fa-trash"></i> Xóa
                                                </button>
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                </div>
            </div>

        </div>
    </div>
</section>