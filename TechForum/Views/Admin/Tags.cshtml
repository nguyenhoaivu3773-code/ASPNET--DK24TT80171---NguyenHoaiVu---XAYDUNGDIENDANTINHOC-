@model TechForum.Models.AdminTagVM
@{
    ViewBag.Title = "Quản lý thẻ";
    Layout = "~/Views/Shared/_LayoutAdmin.cshtml";
}

<section class="content-header">
    <div class="content-header-left">
        <h1>Quản lý thẻ</h1>
    </div>
</section>

<section class="content">

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success">
            <i class="fa fa-check"></i>
            @TempData["SuccessMessage"]
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger">
            <i class="fa fa-warning"></i>
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- HÀNG 1: TẠO THẺ MỚI (NẰM TRÊN) -->
    <div class="row">
        <div class="col-md-12">
            <div class="box box-primary">

                <div class="box-header with-border">
                    <h3 class="box-title">Tạo thẻ mới</h3>
                </div>

                @using (Html.BeginForm("CreateTag", "Admin", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()

                    <div class="box-body">
                        <div class="form-group">
                            <label>Tên thẻ</label>
                            <input type="text"
                                   name="newTagName"
                                   class="form-control"
                                   placeholder="Ví dụ: AI, C#, SQL Server..."
                                   required />
                        </div>
                        <p class="text-muted mb-0">
                            Trạng thái mặc định của thẻ mới là đang hoạt động.
                        </p>
                    </div>

                    <div class="box-footer">
                        <button type="submit" class="btn btn-primary">
                            <i class="fa fa-plus"></i> Thêm thẻ
                        </button>
                    </div>
                }

            </div>
        </div>
    </div>

    <!-- HÀNG 2: DANH SÁCH THẺ (NẰM DƯỚI) -->
    <div class="row">
        <div class="col-md-12">
            <div class="box box-info">

                <div class="box-header with-border">
                    <h3 class="box-title">Danh sách thẻ</h3>
                </div>

                <div class="box-body table-responsive">

                    @if (Model == null || Model.Tags == null || !Model.Tags.Any())
                    {
                        <div class="alert alert-info">
                            Chưa có thẻ nào trong hệ thống.
                        </div>
                    }
                    else
                    {
                        <table id="example1" class="table table-bordered table-hover table-striped">
                            <thead>
                                <tr>
                                    <th width="50">#</th>
                                    <th>Tên thẻ</th>
                                    <th width="150">Số chủ đề</th>
                                    <th width="150">Trạng thái</th>
                                    <th width="150">Thao tác</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    var index = 0;
                                }

                                @foreach (var tag in Model.Tags)
                                {
                                    index++;

                                    <tr>
                                        <td>@index</td>

                                        <td>
                                            <strong>@tag.Name</strong>
                                        </td>

                                        <td>
                                            <strong>@tag.TopicCount</strong>
                                        </td>

                                        <td>
                                            @if (tag.IsActive)
                                            {
                                                <span class="badge" style="background-color:green;">
                                                    Đang hoạt động
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge" style="background-color:red;">
                                                    Đã ẩn
                                                </span>
                                            }
                                        </td>

                                        <td>
                                            @using (Html.BeginForm("ToggleTagStatus", "Admin", FormMethod.Post, new { style = "display:inline;" }))
                                            {
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@tag.Id" />

                                                if (tag.IsActive)
                                                {
                                                    <button type="submit"
                                                            class="btn btn-warning btn-xs"
                                                            onclick="return confirm('Bạn có chắc muốn ẩn thẻ này không?');">
                                                        <i class="fa fa-eye-slash"></i> Ẩn
                                                    </button>
                                                }
                                                else
                                                {
                                                    <button type="submit"
                                                            class="btn btn-success btn-xs"
                                                            onclick="return confirm('Bạn có chắc muốn bật lại thẻ này không?');">
                                                        <i class="fa fa-eye"></i> Bật lại
                                                    </button>
                                                }
                                            }
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }

                </div>
            </div>
        </div>
    </div>

</section>